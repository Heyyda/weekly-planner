# Template для /etc/planner/planner.env на VPS.
# Скопировать на VPS как /etc/planner/planner.env
#   sudo cp server/.env.example /etc/planner/planner.env
#   sudo chmod 600 /etc/planner/planner.env
#   sudo chown root:planner /etc/planner/planner.env
#
# ВНИМАНИЕ: Этот файл содержит ТОЛЬКО PLACEHOLDERS.
# Реальные значения генерируются при bootstrap-vps.sh (deploy/README.md).
# Никогда не коммитить файл с реальными секретами!

# =============================================================================
# ОБЯЗАТЕЛЬНЫЕ ПЕРЕМЕННЫЕ (все должны быть заполнены перед запуском)
# =============================================================================

# Telegram Bot Token (после /revoke через @BotFather — CONTEXT.md D-03)
# КРИТИЧНО: старый токен был скомпрометирован 2026-04-14, ОБЯЗАТЕЛЬНО ревокнуть!
# Инструкция в deploy/README.md STEP 0.
BOT_TOKEN=

# JWT Secrets — генерировать через: openssl rand -hex 32
# Два РАЗНЫХ секрета: access и refresh токены подписываются независимо (D-14)
JWT_SECRET=
JWT_REFRESH_SECRET=

# SQLite база данных на VPS (путь должен быть доступен пользователю planner)
# 4 слеша = абсолютный путь в SQLAlchemy URL (sqlite+aiosqlite:////абс/путь)
DATABASE_URL=sqlite+aiosqlite:////var/lib/planner/weekly_planner.db

# Allow-list Telegram usernames (comma-separated, без @, lowercase)
# Только пользователи из этого списка могут запросить auth-код (D-27)
# Пример: ALLOWED_USERNAMES=nikita_heyyda,colleague_ivan
ALLOWED_USERNAMES=nikita_heyyda

# =============================================================================
# ОПЦИОНАЛЬНЫЕ ПЕРЕМЕННЫЕ (можно не указывать — defaults в server/config.py)
# =============================================================================

# Сервер слушает только localhost (за reverse-proxy — CONTEXT.md D-10)
# HOST=127.0.0.1

# Порт backend сервера (reverse-proxy проксирует снаружи на этот порт)
# PORT=8100

# Версия приложения (отображается в /api/version)
# APP_VERSION=0.1.0

# Уровень логирования (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO

# TTL токенов (в секундах, значения по умолчанию из CONTEXT.md D-12, D-13, D-07)
# ACCESS_TOKEN_TTL_SECONDS=900       # 15 минут
# REFRESH_TOKEN_TTL_SECONDS=2592000  # 30 дней
# AUTH_CODE_TTL_SECONDS=300          # 5 минут
# AUTH_CODE_LENGTH=6                 # 6 цифр
